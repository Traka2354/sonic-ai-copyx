# ============================================================
#  Gold AI Bot - konfiguracija
#  Kopiraj ovaj fajl u ".env" i popuni svojim podacima.
#  .env NIKAD ne commituj u git (vidi .gitignore).
# ============================================================

# ---- Koji nalog se koristi: "demo" ili "live" ----
ACCOUNT_MODE=demo

# ---- DEMO nalog (MT5) ----
DEMO_MT5_LOGIN=
DEMO_MT5_PASSWORD=
DEMO_MT5_SERVER=
# Putanja do terminal64.exe (opciono; ostavi prazno ako je MT5 vec pokrenut)
DEMO_MT5_PATH=

# ---- LIVE (realni) nalog (MT5) ----
LIVE_MT5_LOGIN=
LIVE_MT5_PASSWORD=
LIVE_MT5_SERVER=
LIVE_MT5_PATH=

# ---- Instrument ----
# Kod TAG Markets zlato se zove XAUUSD.f (proveri tacan naziv u Market Watch).
SYMBOL=XAUUSD.f

# ---- Risk (procenat od UKUPNOG BALANSA naloga po trejdu) ----
# TP 1-3%, SL 0.5-1%. Bira se unutar opsega prema sigurnosti AI signala.
TP_MIN_PCT=0.01
TP_MAX_PCT=0.03
SL_MIN_PCT=0.005
SL_MAX_PCT=0.01

# Auto-skaliranje lota: lot se racuna iz rizika (SL% balansa). Preporuceno.
AUTO_LOT=true
# Fallback lot kad auto-skaliranje ne moze da racuna. 0.01 = mikrolot.
LOT_SIZE=0.01
# Gornji limit velicine pozicije (zastita od prevelikog lota).
MAX_LOT=1.0

# SL razdaljina se racuna iz volatilnosti (ATR). SL = ATR_SL_MULT * ATR.
ATR_PERIOD=14
ATR_SL_MULT=1.5
# Ako ATR nije dostupan: SL razdaljina = SL_FALLBACK_PCT * trenutna cena.
SL_FALLBACK_PCT=0.005

# ---- Zastite ----
MAX_OPEN_POSITIONS=1
MAX_DAILY_LOSS_PCT=0.05
# Minimalna sigurnost AI signala (0-1) da bi se otvorila pozicija
MIN_CONFIDENCE=0.6
# Koliko sekundi izmedju provera trzista
POLL_INTERVAL_SEC=60

# Nivo logovanja: DEBUG, INFO, WARNING, ERROR (logs/bot.log)
LOG_LEVEL=INFO

# Folder za log i stanje. Promeni ga ako pokreces VISE instanci bota
# (npr. STATE_DIR=logs_12x za zastitu, STATE_DIR=logs_copy za kopiju).
STATE_DIR=logs

# Za "signal mode" (python signal.py) - balans naloga za predlog lota.
# 0 = bot ne predlaze lot, samo entry/SL/TP cene.
SIGNAL_BALANCE=0

# ---- Telegram obavestenja (signali + alarmi na iPhone/Android) ----
# Setup: @BotFather za TOKEN, pa otvori
# https://api.telegram.org/bot<TOKEN>/getUpdates da nadjes CHAT_ID.
# Ostavi prazno ako ne zelis Telegram.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Magic broj kojim bot oznacava SVOJE (AI) pozicije (radi trailing/upravljanja)
BOT_MAGIC=770077

# ---- Trailing stop + break-even (zastita profita) ----
TRAILING_ENABLED=true
# SL na ulaz (break-even) kad profit dostigne BE_ATR_MULT * ATR
BE_ATR_MULT=1.0
# pocni trailing kad profit dostigne TRAIL_START_MULT * ATR
TRAIL_START_MULT=1.5
# SL prati cenu na razdaljini TRAIL_ATR_MULT * ATR
TRAIL_ATR_MULT=1.0
# fallback razdaljine ako ATR nije dostupan (procenat cene)
TRAIL_FALLBACK_PCT=0.004

# ---- Filteri ulaska ----
# Max dozvoljen spread (u ceni, npr. 0.80 = 80 centi za zlato). 0 = iskljuceno.
MAX_SPREAD=0.80
# Sati trgovanja u UTC (likvidni London/NY prozor). START==END => 24h.
TRADE_START_HOUR=7
TRADE_END_HOUR=21
# Da li trgovati vikendom (zlato je obicno zatvoreno)
TRADE_WEEKENDS=false

# ---- Zastitni circuit breakeri ----
# Kad equity poraste za toliko za dan -> stani i poknjizi dan (0 = iskljuceno)
DAILY_PROFIT_TARGET_PCT=0.05
# Posle toliko uzastopnih gubitaka -> pauza do kraja dana (0 = iskljuceno)
MAX_CONSEC_LOSSES=3
# Posle gubitka saceka toliko minuta pre novog ulaza (anti-revenge trading)
COOLDOWN_MIN=30

# ---- Tvrda zastita ukupnog drawdown-a (za 12X / funded nalog) ----
# Broker te izbacuje na ~10%; stani sa rezervom (npr. 6%) i ostani zaustavljen
# do kraja dana. Pri probijanju se (po default-u) zatvaraju sve pozicije.
MAX_TOTAL_DRAWDOWN_PCT=0.06
# Pocetni balans naloga za merenje DD. Za 12X stavi POJACANI iznos (npr. 1200
# ako je 12x od 100). 0 = bot sam uzme trenutni balans pri prvom pokretanju.
ACCOUNT_BASELINE=0
# DD se meri od pika (true) ili od pocetnog balansa (false). Funded = false.
DRAWDOWN_TRAILING=false
# Pri probijanju DD limita zatvori sve pozicije (preporuceno za funded nalog)
DRAWDOWN_FLATTEN=true

# ---- AI mozak (Claude API) ----
AI_ENABLED=true
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-7
# Da li AI sme da pretrazuje web za vesti (web_search alat)
AI_WEB_RESEARCH=true

# ---- Copy trading (kopiranje signala sa MASTER naloga na MOJ nalog) ----
COPY_ENABLED=false
# MASTER = nalog ciji se signali kopiraju (npr. investor/read-only login).
COPY_MASTER_LOGIN=
COPY_MASTER_PASSWORD=
COPY_MASTER_SERVER=
COPY_MASTER_PATH=
# Mnozilac veličine pozicije pri kopiranju (1.0 = isto, 0.5 = pola)
COPY_LOT_MULTIPLIER=1.0
# Magic broj kojim bot oznacava kopirane pozicije (da ih razlikuje od svojih)
COPY_MAGIC=778899
